modules = ["nodejs-20"]

[nix]
channel = "stable-24_05"

[[ports]]
localPort = 5000
externalPort = 5000

[[ports]]
localPort = 8081
externalPort = 80

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "VibesFlow Server"

[[workflows.workflow]]
name = "VibesFlow Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "expo start --web --port 5000"
waitForPort = 5000

[deployment]
run = ["sh", "-c", "expo start --web --port 5000"]
